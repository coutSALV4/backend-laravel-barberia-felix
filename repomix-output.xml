    public function getAllUsers(?string $role = null)
    {
        $query = User::query();

        if ($role) {
            $query->where('role', $role);
        }

        return $query->paginate(10); 
    }

    public function getUserById($id)
    {
        return User::findOrFail($id);
    }

    public function updateUser(User $user, array $data)
    {
        $user->update($data);
        return $user;
    }

}
