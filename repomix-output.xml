class UserResource extends JsonResource
{
    public function toArray(Request $request): array
    {
        return [
            'id'         => $this->id,
            'name'       => $this->name,
            'lastname'   => $this->lastname,
            'email'      => $this->email,
            'phone'      => $this->phone,
            'role'       => $this->role,
        ];
    }
}
